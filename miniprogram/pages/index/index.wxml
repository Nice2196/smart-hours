<!--
  首页 - 课程总览
  设计语言：「墨蓝 · 纸白」
  结构：渐变统计头 → 预警区 → 筛选栏 → 课程列表 → FAB
-->
<view class="page-container">

  <!-- ==================== 渐变统计头 ==================== -->
  <view class="hero-stats" wx:if="{{!isEmpty && !loading}}">
    <view class="hero-bg"></view>
    <view class="hero-content">
      <view class="hero-greeting">
        <text class="hero-title">课时总览</text>
        <text class="hero-subtitle">管理你的每一节课</text>
      </view>
      <view class="hero-metrics">
        <view class="metric-item">
          <text class="metric-value">{{stats.activeCourses || 0}}</text>
          <text class="metric-label">进行中</text>
        </view>
        <view class="metric-divider"></view>
        <view class="metric-item">
          <text class="metric-value">{{stats.totalRemainingHours || 0}}</text>
          <text class="metric-label">剩余课时</text>
        </view>
        <view class="metric-divider"></view>
        <view class="metric-item">
          <text class="metric-value">{{stats.monthlyDeductionHours || 0}}</text>
          <text class="metric-label">本月消课</text>
        </view>
      </view>
    </view>
  </view>

  <!-- ==================== 预警区 ==================== -->
  <view class="warnings-section" wx:if="{{lowHoursWarnings.length > 0 || expiryWarnings.length > 0}}">
    <!-- 低课时预警 -->
    <view class="warning-card warning-card-expired" wx:if="{{lowHoursWarnings.length > 0}}">
      <view class="warning-header">
        <view class="warning-dot warning-dot-expired"></view>
        <text class="warning-title">课时不足</text>
        <text class="warning-count">{{lowHoursWarnings.length}}门</text>
      </view>
      <view class="warning-body">
        <text class="warning-detail" wx:for="{{lowHoursWarnings}}" wx:key="courseId">
          {{item.courseName}} 剩余 {{item.remainingHours}} 节
          <text wx:if="{{index < lowHoursWarnings.length - 1}}" class="warning-sep"> · </text>
        </text>
      </view>
    </view>

    <!-- 即将过期预警 -->
    <view class="warning-card warning-card-warning" wx:if="{{expiryWarnings.length > 0}}">
      <view class="warning-header">
        <view class="warning-dot warning-dot-warning"></view>
        <text class="warning-title">即将过期</text>
        <text class="warning-count">{{expiryWarnings.length}}门</text>
      </view>
      <view class="warning-body">
        <text class="warning-detail" wx:for="{{expiryWarnings}}" wx:key="courseId">
          {{item.courseName}} {{item.daysUntilExpiry}}天后到期
          <text wx:if="{{index < expiryWarnings.length - 1}}" class="warning-sep"> · </text>
        </text>
      </view>
    </view>
  </view>

  <!-- ==================== 课程列表区 ==================== -->
  <block wx:if="{{!loading}}">

    <!-- 筛选栏 -->
    <view class="filter-bar" wx:if="{{!isEmpty}}">
      <scroll-view scroll-x class="filter-scroll">
        <view class="filter-items">
          <view
            class="filter-item {{activeFilter === '' ? 'active' : ''}}"
            data-filter=""
            bindtap="onFilterChange"
          >全部</view>
          <view
            class="filter-item {{activeFilter === 'active' ? 'active' : ''}}"
            data-filter="active"
            bindtap="onFilterChange"
          >进行中</view>
          <view
            class="filter-item {{activeFilter === 'paused' ? 'active' : ''}}"
            data-filter="paused"
            bindtap="onFilterChange"
          >已暂停</view>
          <view
            class="filter-item {{activeFilter === 'completed' ? 'active' : ''}}"
            data-filter="completed"
            bindtap="onFilterChange"
          >已完成</view>
          <view
            class="filter-item {{activeFilter === 'expired' ? 'active' : ''}}"
            data-filter="expired"
            bindtap="onFilterChange"
          >已过期</view>
        </view>
      </scroll-view>
    </view>

    <!-- 空状态 -->
    <empty-state
      wx:if="{{filteredCourses.length === 0}}"
      icon="📚"
      text="{{isEmpty ? '还没有课程记录' : '没有匹配的课程'}}"
      subText="{{isEmpty ? '点击下方按钮添加第一门课程' : '尝试切换筛选条件'}}"
    />

    <!-- 课程卡片列表 -->
    <view class="course-list" wx:else>
      <course-card
        wx:for="{{filteredCourses}}"
        wx:key="_id"
        course="{{item}}"
      />
    </view>
  </block>

  <!-- 加载骨架屏 -->
  <view class="skeleton-container" wx:if="{{loading}}">
    <view class="skeleton-hero"></view>
    <view class="skeleton-card" wx:for="{{[1,2,3]}}" wx:key="*this"></view>
  </view>

  <!-- ==================== 底部新增按钮 ==================== -->
  <view class="fab-container">
    <button class="fab-btn" bindtap="onAddCourse">
      <text class="fab-icon">＋</text>
      <text class="fab-text">新增课程</text>
    </button>
  </view>

</view>
