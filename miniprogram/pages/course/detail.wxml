<!--
  课程详情页
  设计语言：「墨蓝 · 纸白」
-->
<view class="page-container" wx:if="{{!loading && course}}">

  <!-- ==================== 课程信息卡片 ==================== -->
  <view class="info-card card-accent card-status-{{course.status}}">
    <view class="card-header">
      <text class="course-name">{{course.name}}</text>
      <view class="tag tag-{{course.status}}">{{courseStatusLabel}}</view>
    </view>

    <!-- 进度区 -->
    <view class="progress-section">
      <view class="progress-track">
        <view class="progress-fill" style="width: {{course.consumedHours / course.totalHours * 100}}%"></view>
      </view>
      <view class="progress-text">
        <text class="progress-consumed">已消耗 {{course.consumedHours || 0}} 课时</text>
        <text class="progress-remaining">剩余 {{course.remainingHours}} / 总计 {{course.totalHours}}</text>
      </view>
    </view>

    <!-- 详情信息 -->
    <view class="info-grid">
      <view class="info-item">
        <text class="info-label">科目</text>
        <text class="info-value">{{course._subjectLabel}}</text>
      </view>
      <view class="info-item">
        <text class="info-label">类型</text>
        <text class="info-value">{{course._courseTypeLabel}}</text>
      </view>
      <view class="info-item">
        <text class="info-label">学生</text>
        <text class="info-value">{{course.student || '-'}}</text>
      </view>
      <view class="info-item">
        <text class="info-label">老师</text>
        <text class="info-value">{{course.teacher || '-'}}</text>
      </view>
      <view class="info-item">
        <text class="info-label">每次扣课</text>
        <text class="info-value">{{course.deductionUnit || 1}} 课时</text>
      </view>
      <view class="info-item" wx:if="{{course._startDate}}">
        <text class="info-label">开始日期</text>
        <text class="info-value">{{course._startDate}}</text>
      </view>
      <view class="info-item" wx:if="{{course._expiryDate}}">
        <text class="info-label">过期日期</text>
        <text class="info-value">{{course._expiryDate}}</text>
      </view>
      <view class="info-item info-item-full" wx:if="{{course.notes}}">
        <text class="info-label">备注</text>
        <text class="info-value">{{course.notes}}</text>
      </view>
    </view>
  </view>

  <!-- ==================== 固定排课 ==================== -->
  <view class="section-card">
    <view class="section-header">
      <text class="section-title">固定排课</text>
      <text class="section-action" bindtap="onAddSchedule">+ 添加</text>
    </view>

    <view wx:if="{{schedules.length > 0}}">
      <view
        class="schedule-item"
        wx:for="{{schedules}}"
        wx:key="_id"
        data-schedule-id="{{item._id}}"
        bindtap="onEditSchedule"
      >
        <view class="schedule-weekday">
          <text class="weekday-badge">{{item.weekdayLabel}}</text>
        </view>
        <text class="schedule-time">{{item.time}}</text>
        <view class="tag tag-{{item.status === 'active' ? 'success' : 'warning'}}">
          {{item.status === 'active' ? '启用' : '暂停'}}
        </view>
      </view>
    </view>

    <view class="empty-hint" wx:else>
      <text class="empty-hint-text">暂未设置固定排课</text>
      <text class="empty-hint-sub">设置后可按周期自动消课</text>
    </view>
  </view>

  <!-- ==================== 操作按钮组 ==================== -->
  <view class="action-group">
    <button class="btn btn-primary btn-block" bindtap="onQuickDeduct">
      手动消课
    </button>
    <button class="btn btn-outline btn-block" bindtap="onViewLessons">
      消课记录
    </button>
    <button class="btn btn-outline btn-block" bindtap="onEdit">
      编辑课程
    </button>
    <button
      class="btn btn-outline btn-block {{course.status === 'active' ? 'btn-warning-outline' : 'btn-success-outline'}}"
      bindtap="onToggleStatus"
    >
      {{course.status === 'active' ? '暂停课程' : '恢复课程'}}
    </button>
    <button class="btn btn-ghost btn-block btn-danger-text" bindtap="onDelete">
      删除课程
    </button>
  </view>

</view>

<!-- 空状态 -->
<view wx:if="{{!loading && !course}}">
  <empty-state
    icon="📚"
    text="课程未找到"
    subText="该课程可能已被删除"
  />
</view>

<!-- 加载中 -->
<view class="loading-container" wx:if="{{loading}}">
  <view class="loading-spinner"></view>
  <text class="loading-text">加载中...</text>
</view>

<!-- 底部安全距离 -->
<view class="safe-bottom"></view>
