/**
 * 数据统计页样式
 * 设计语言：「墨蓝 · 纸白」
 */

.page-container {
  min-height: 100vh;
  background-color: var(--color-bg);
}

/* ==================== Tab 栏 ==================== */
.tab-bar {
  display: flex;
  flex-direction: row;
  background: var(--color-card);
  border-bottom: 1rpx solid var(--color-border);
  position: sticky;
  top: 0;
  z-index: 10;
}

.tab-item {
  flex: 1;
  position: relative;
  text-align: center;
  padding: var(--spacing-md) var(--spacing-sm);
  font-size: var(--font-size-base);
  color: var(--color-text-secondary);
  font-weight: 500;
  transition: color 0.2s var(--ease-out);
}

.tab-item.active {
  color: var(--color-primary);
  font-weight: 600;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 25%;
  right: 25%;
  height: 4rpx;
  background: var(--color-primary);
  border-radius: 2rpx 2rpx 0 0;
}

.tab-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: var(--color-expired);
  color: #FFFFFF;
  font-size: 20rpx;
  min-width: 32rpx;
  height: 32rpx;
  padding: 0 8rpx;
  border-radius: 16rpx;
  margin-left: 6rpx;
  vertical-align: super;
  line-height: 1;
  font-weight: 600;
}

.tab-content {
  padding: var(--spacing-md);
}

/* ==================== 指标网格 ==================== */
.metric-grid {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: var(--spacing-sm);
}

.metric-card {
  flex: 1 1 45%;
  background: var(--color-card);
  border-radius: var(--radius-md);
  padding: var(--spacing-md);
  box-shadow: var(--shadow-card);
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  border-left: 6rpx solid var(--color-border);
}

.metric-card-primary {
  border-left-color: var(--color-primary);
}

.metric-card-warning {
  border-left-color: var(--color-warning);
}

.metric-card-success {
  border-left-color: var(--color-success);
}

.metric-number {
  font-size: var(--font-size-2xl);
  font-weight: 700;
  color: var(--color-text-primary);
  line-height: 1.2;
}

.metric-card-primary .metric-number {
  color: var(--color-primary);
}

.metric-card-warning .metric-number {
  color: var(--color-warning);
}

.metric-card-success .metric-number {
  color: var(--color-success);
}

.metric-label {
  font-size: var(--font-size-xs);
  color: var(--color-text-helper);
  margin-top: 6rpx;
  letter-spacing: 0.04em;
}

/* ==================== 高亮卡片 ==================== */
.highlight-card {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  background: linear-gradient(135deg, #4F46E5 0%, #7C3AED 100%);
  border-radius: var(--radius-md);
  padding: var(--spacing-lg);
  margin-top: var(--spacing-md);
  box-shadow: 0 4rpx 16rpx rgba(79, 70, 229, 0.2);
}

.highlight-left {
  display: flex;
  flex-direction: column;
}

.highlight-label {
  font-size: var(--font-size-sm);
  color: rgba(255, 255, 255, 0.75);
  letter-spacing: 0.04em;
}

.highlight-value {
  font-size: var(--font-size-2xl);
  font-weight: 700;
  color: #FFFFFF;
  margin-top: 4rpx;
}

.highlight-ring {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 50%;
}

.highlight-ring-icon {
  font-size: 40rpx;
}

/* ==================== 图表卡片 ==================== */
.chart-card {
  background: var(--color-card);
  border-radius: var(--radius-md);
  padding: var(--spacing-lg);
  margin-top: var(--spacing-md);
  box-shadow: var(--shadow-card);
}

.chart-title {
  font-size: var(--font-size-base);
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: var(--spacing-md);
  display: block;
}

/* ==================== 区块卡片 ==================== */
.section-card {
  background: var(--color-card);
  border-radius: var(--radius-md);
  padding: var(--spacing-lg);
  margin-bottom: var(--spacing-md);
  box-shadow: var(--shadow-card);
}

.section-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: var(--spacing-md);
}

.section-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  margin-right: var(--spacing-xs);
  flex-shrink: 0;
}

.section-dot-warning {
  background: var(--color-warning);
}

.section-dot-danger {
  background: var(--color-expired);
}

.section-title {
  font-size: var(--font-size-base);
  font-weight: 600;
  color: var(--color-text-primary);
}

/* ==================== 课程分布 ==================== */
.breakdown-item {
  padding: var(--spacing-sm) 0;
  border-bottom: 1rpx solid var(--color-border);
}

.breakdown-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.bi-header {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.bi-name {
  font-size: var(--font-size-sm);
  color: var(--color-text-primary);
  font-weight: 500;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.bi-percent {
  font-size: var(--font-size-sm);
  color: var(--color-primary);
  font-weight: 600;
  margin-left: var(--spacing-sm);
  flex-shrink: 0;
}

.progress-track {
  height: 8rpx;
  background: var(--color-border);
  border-radius: 4rpx;
  overflow: hidden;
  margin-bottom: 8rpx;
}

.progress-fill {
  height: 100%;
  background: var(--color-success);
  border-radius: 4rpx;
  transition: width 0.5s var(--ease-out);
}

.bi-footer {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
}

.bi-stat {
  font-size: var(--font-size-xs);
  color: var(--color-text-helper);
}

/* ==================== 预警列表 ==================== */
.warn-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: var(--spacing-sm) 0;
  border-bottom: 1rpx solid var(--color-border);
  transition: background 0.15s;
}

.warn-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.warn-item:active {
  opacity: 0.7;
}

.warn-accent {
  width: 6rpx;
  height: 48rpx;
  border-radius: 3rpx;
  margin-right: var(--spacing-sm);
  flex-shrink: 0;
}

.warn-accent-warning {
  background: var(--color-warning);
}

.warn-accent-danger {
  background: var(--color-expired);
}

.warn-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.warn-name {
  font-size: var(--font-size-sm);
  color: var(--color-text-primary);
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.warn-detail {
  font-size: var(--font-size-xs);
  color: var(--color-text-helper);
  margin-top: 4rpx;
}

.warn-arrow {
  font-size: var(--font-size-xl);
  color: var(--color-text-disabled);
  margin-left: var(--spacing-sm);
  flex-shrink: 0;
}

/* ==================== 加载 ==================== */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--spacing-2xl);
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid var(--color-border);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: var(--spacing-sm);
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  color: var(--color-text-helper);
  font-size: var(--font-size-sm);
}

.safe-bottom {
  height: 40rpx;
}
