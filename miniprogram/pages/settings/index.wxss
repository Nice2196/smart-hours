/**
 * 设置页样式
 * 设计语言：「墨蓝 · 纸白」
 */

.page-container {
  min-height: 100vh;
  background-color: var(--color-bg);
  padding: var(--spacing-md);
}

/* ==================== 区块卡片 ==================== */
.section-card {
  background: var(--color-card);
  border-radius: var(--radius-md);
  padding: var(--spacing-md) var(--spacing-lg);
  margin-bottom: var(--spacing-md);
  box-shadow: var(--shadow-card);
}

.section-label {
  display: block;
  font-size: var(--font-size-xs);
  font-weight: 600;
  color: var(--color-text-helper);
  text-transform: uppercase;
  letter-spacing: 0.1em;
  margin-bottom: var(--spacing-sm);
  padding-bottom: var(--spacing-sm);
  border-bottom: 1rpx solid var(--color-border);
}

/* ==================== 设置项 ==================== */
.setting-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: var(--spacing-md) 0;
  border-bottom: 1rpx solid var(--color-border);
  gap: var(--spacing-md);
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-item:active {
  opacity: 0.7;
}

.si-left {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.si-label {
  font-size: var(--font-size-base);
  color: var(--color-text-primary);
  font-weight: 500;
}

.si-hint {
  font-size: var(--font-size-xs);
  color: var(--color-text-helper);
  margin-top: 4rpx;
}

.si-action {
  font-size: var(--font-size-sm);
  color: var(--color-primary);
  font-weight: 500;
  flex-shrink: 0;
}

.si-arrow {
  font-size: var(--font-size-xl);
  color: var(--color-text-disabled);
  flex-shrink: 0;
}

/* 输入框 */
.si-input-group {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: var(--spacing-xs);
}

.si-input {
  width: 80rpx;
  height: 64rpx;
  text-align: center;
  background: var(--color-bg);
  border-radius: var(--radius-sm);
  border: 2rpx solid var(--color-border);
  font-size: var(--font-size-base);
  color: var(--color-text-primary);
  transition: border-color 0.2s;
}

.si-input:focus {
  border-color: var(--color-primary);
}

.si-input-sm {
  width: 100rpx;
}

.si-input-wide {
  width: 280rpx;
  height: 64rpx;
  text-align: left;
  padding: 0 var(--spacing-sm);
}

.si-unit {
  font-size: var(--font-size-xs);
  color: var(--color-text-helper);
}

/* ==================== 用户头像 ==================== */
.user-profile {
  padding: var(--spacing-md) 0;
}

.avatar-btn {
  padding: 0;
  margin: 0;
  background: transparent;
  border: none;
  line-height: 0;
  flex-shrink: 0;
  margin-right: var(--spacing-md);
}

.avatar-btn::after {
  border: none;
}

.user-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  flex-shrink: 0;
  display: block;
  border: 4rpx solid var(--color-primary-soft);
}

.user-avatar-placeholder {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: var(--color-primary-light);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.avatar-icon {
  font-size: 44rpx;
}

.user-profile .si-left {
  min-width: 0;
  overflow: hidden;
}

.user-profile .si-label {
  font-size: var(--font-size-lg);
  font-weight: 600;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 400rpx;
}

/* ==================== 关于 ==================== */
.about-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: var(--spacing-sm) 0;
  border-bottom: 1rpx solid var(--color-border);
}

.about-row:last-child {
  border-bottom: none;
}

.about-label {
  width: 140rpx;
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  flex-shrink: 0;
}

.about-value {
  font-size: var(--font-size-sm);
  color: var(--color-text-primary);
  flex: 1;
}

/* ==================== 使用说明 ==================== */
.help-list {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-sm);
}

.help-item {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  gap: var(--spacing-sm);
}

.help-num {
  width: 36rpx;
  height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--color-primary-light);
  color: var(--color-primary);
  font-size: 22rpx;
  font-weight: 600;
  border-radius: 50%;
  flex-shrink: 0;
  margin-top: 2rpx;
}

.help-text {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  line-height: 1.6;
  flex: 1;
}

/* ==================== 底部 ==================== */
.safe-bottom {
  height: 80rpx;
}
