/**
 * 消课记录列表页样式
 * 设计语言：「墨蓝 · 纸白」
 */

.page-container {
  min-height: 100vh;
  background-color: var(--color-bg);
  padding: var(--spacing-md);
}

/* 课程头部 */
.course-header {
  background: var(--color-card);
  border-radius: var(--radius-md);
  padding: var(--spacing-md) var(--spacing-lg);
  margin-bottom: var(--spacing-md);
  box-shadow: var(--shadow-card);
  border-left: 6rpx solid var(--color-primary);
}

.course-title {
  font-size: var(--font-size-lg);
  font-weight: 700;
  color: var(--color-text-primary);
  display: block;
}

.lesson-count {
  font-size: var(--font-size-xs);
  color: var(--color-text-helper);
  margin-top: 4rpx;
  display: block;
}

/* 记录卡片 */
.lesson-item {
  background: var(--color-card);
  border-radius: var(--radius-md);
  padding: var(--spacing-md) var(--spacing-lg);
  margin-bottom: var(--spacing-sm);
  box-shadow: var(--shadow-card);
}

.lesson-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: var(--spacing-sm);
}

.lesson-date {
  font-size: var(--font-size-base);
  font-weight: 600;
  color: var(--color-text-primary);
  flex: 1;
}

.lesson-tag {
  font-size: 22rpx;
  padding: 2rpx 10rpx;
  border-radius: 4rpx;
  margin-left: var(--spacing-xs);
  font-weight: 500;
}

.lesson-tag.auto {
  color: var(--color-primary);
  background: var(--color-pending-light);
}

.lesson-tag.manual {
  color: #7C3AED;
  background: #EDE9FE;
}

.lesson-tag.completed {
  color: var(--color-success);
  background: var(--color-success-light);
}

.lesson-tag.cancelled {
  color: var(--color-expired);
  background: var(--color-expired-light);
}

.lesson-body {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  margin-bottom: var(--spacing-sm);
}

.lb-left {
  display: flex;
  flex-direction: column;
}

.lb-hours {
  font-size: var(--font-size-lg);
  font-weight: 700;
  color: var(--color-expired);
}

.lb-time {
  font-size: var(--font-size-xs);
  color: var(--color-text-helper);
  margin-top: 4rpx;
}

.lb-right {
  flex: 1;
  margin-left: var(--spacing-md);
}

.lb-notes {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  line-height: 1.5;
  word-break: break-all;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.lesson-footer {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding-top: var(--spacing-sm);
  border-top: 1rpx solid var(--color-border);
}

.lf-balance {
  font-size: var(--font-size-xs);
  color: var(--color-text-helper);
}

.lf-cancel-btn {
  font-size: var(--font-size-xs);
  color: var(--color-expired);
  padding: 6rpx 20rpx;
  border: 2rpx solid var(--color-expired);
  border-radius: var(--radius-sm);
  font-weight: 500;
}

.lf-cancel-btn:active {
  background: var(--color-expired-light);
}

.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--spacing-2xl);
}

.loading-text {
  color: var(--color-text-helper);
  font-size: var(--font-size-sm);
}

.error-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--spacing-2xl);
  gap: var(--spacing-md);
}

.error-text {
  color: var(--color-text-secondary);
  font-size: var(--font-size-sm);
}

.btn-retry {
  font-size: var(--font-size-sm);
  color: var(--color-primary);
  background: transparent;
  border: 2rpx solid var(--color-primary-soft);
  border-radius: var(--radius-md);
  padding: 10rpx 40rpx;
  line-height: 1.5;
  font-weight: 500;
}

.btn-retry:active {
  background: var(--color-primary-light);
}

.safe-bottom {
  height: 40rpx;
}
