/**
 * 日历网格组件样式
 * 设计语言：「墨蓝 · 纸白」
 */

.calendar-grid {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  padding: var(--spacing-xs);
  background: var(--color-card);
}

.cell-wrapper {
  width: calc(100% / 7);
  aspect-ratio: 1;
  box-sizing: border-box;
  padding: 3rpx;
}

.cell {
  width: 100%;
  height: 100%;
  border-radius: var(--radius-sm);
  display: flex;
  align-items: center;
  justify-content: center;
}

.cell-other-month {
  opacity: 0.25;
}

.cell-inner {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-sm);
  position: relative;
  transition: background 0.15s;
}

.cell-inner.today {
  background: var(--color-primary-light);
  border: 2rpx solid var(--color-primary);
}

.cell-inner.has-lessons:not(.today) {
  background: rgba(79, 70, 229, 0.04);
}

.cell-day {
  font-size: 26rpx;
  color: var(--color-text-primary);
  font-weight: 500;
  line-height: 1.2;
}

.today-text {
  font-weight: 700;
  color: var(--color-primary);
}

/* ==================== 课程标记 ==================== */
.cell-dots {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 4rpx;
  margin-top: 4rpx;
}

.dots-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  gap: 3rpx;
}

.dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.dot-completed {
  background: var(--color-success);
}

.dot-pending {
  background: var(--color-pending);
}

.dot-expired {
  background: var(--color-expired);
}

.cell-count {
  font-size: 16rpx;
  color: var(--color-text-helper);
  line-height: 1;
  font-weight: 500;
}
