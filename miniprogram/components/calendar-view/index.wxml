<!--
  日历网格组件
  设计语言：「墨蓝 · 纸白」
-->
<view class="calendar-grid">

  <view
    class="cell-wrapper"
    wx:for="{{cells}}"
    wx:key="date"
    data-date="{{item.date}}"
    bindtap="onDayTap"
  >
    <view class="cell {{item.isCurrentMonth ? '' : 'cell-other-month'}}">
      <view class="cell-inner {{item.isToday ? 'today' : ''}} {{item.info && item.info.lessonCount > 0 ? 'has-lessons' : ''}}">

        <!-- 日期数字 -->
        <text class="cell-day {{item.isToday ? 'today-text' : ''}}">{{item.day}}</text>

        <!-- 课程标记点 -->
        <view class="cell-dots" wx:if="{{item.info && item.info.lessonCount > 0}}">
          <view class="dots-row">
            <view class="dot dot-completed" wx:if="{{item.info.completedCount > 0}}"></view>
            <view class="dot dot-pending" wx:if="{{item.info.pendingCount > 0}}"></view>
            <view class="dot dot-expired" wx:if="{{item.info.expiredCount > 0}}"></view>
          </view>
          <text class="cell-count" wx:if="{{item.info.lessonCount > 1}}">{{item.info.lessonCount}}</text>
        </view>

      </view>
    </view>
  </view>

</view>
